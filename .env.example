# ╔═══════════════════════════════════════════════════════════════╗
# ║  CẤU HÌNH FACEBOOK SCANNER — ĐIỀN THÔNG TIN CỦA BẠN VÀO ĐÂY ║
# ╚═══════════════════════════════════════════════════════════════╝
#
# SAO CHÉP FILE NÀY THÀNH .env TRƯỚC KHI ĐIỀN:
#   copy .env.example .env
#

# ────────────────────────────────────────────────────────────────
# 1. TELEGRAM BOT — ĐỂ NHẬN THÔNG BÁO BÀI VIẾT MỚI
# ────────────────────────────────────────────────────────────────
# Bước 1: Mở Telegram, tìm @BotFather
# Bước 2: Gửi /newbot → đặt tên → nhận TOKEN
# Bước 3: Dán TOKEN vào đây (VD: 123456:ABC-DEF...)
TELEGRAM_BOT_TOKEN=

# Bước 4: Mở @userinfobot hoặc @RawDataBot trên Telegram
# Bước 5: Gửi /start → nó sẽ hiện Chat ID của bạn (VD: 123456789)
TELEGRAM_CHAT_ID=

# ────────────────────────────────────────────────────────────────
# 2. FACEBOOK COOKIES — ĐỂ ĐĂNG NHẬP FACEBOOK TỰ ĐỘNG
# ────────────────────────────────────────────────────────────────
# Cách lấy cookies:
#   Bước 1: Đăng nhập Facebook trên Chrome
#   Bước 2: Cài extension "EditThisCookie" hoặc "Cookie-Editor"
#   Bước 3: Mở facebook.com → click extension → Export dạng JSON
#   Bước 4: Lưu file JSON vào fb-scanner/cookies.json
#
# HOẶC dán cookies dạng chuỗi vào đây (VD: c_user=123; xs=abc; datr=xyz)
FB_COOKIES=

# ────────────────────────────────────────────────────────────────
# 3. TÙY CHỌN NÂNG CAO (có thể bỏ qua)
# ────────────────────────────────────────────────────────────────
# Chu kỳ quét (phút) — mặc định 30 phút
SCAN_INTERVAL_MINUTES=30

# Số bài tối đa quét mỗi group — mặc định 30
MAX_POSTS_PER_GROUP=30

# Bài viết cũ hơn X ngày sẽ bị bỏ qua — mặc định 3 ngày
MAX_POST_AGE_DAYS=3
